{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/ai-chat.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/sync-push-history.js": {
      "maxDuration": 300,
      "memory": 512
    },
    "api/daily-health-alert.js": {
      "maxDuration": 120,
      "memory": 512
    },
    "api/backfill-events.js": {
      "maxDuration": 300,
      "memory": 512
    }
  },
  "crons": [
    {
      "path": "/api/sync-push-history",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/daily-health-alert",
      "schedule": "0 7 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path((?!api/).*)",
      "has": [
        {
          "type": "host",
          "value": "growapp-crm.vercel.app"
        }
      ],
      "destination": "https://crm.comune.digital/:path",
      "permanent": true
    },
    {
      "source": "/((?!storico-notifiche)(?!api/)(?!js/)(?!css/).*)",
      "has": [
        {
          "type": "host",
          "value": "notifiche.comune.digital"
        }
      ],
      "destination": "https://notifiche.comune.digital/storico-notifiche/landing.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/css/(.*)",
      "destination": "/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/js/$1"
    },
    {
      "source": "/img/(.*)",
      "destination": "/img/$1"
    },
    {
      "source": "/firebase-messaging-sw.js",
      "destination": "/firebase-messaging-sw.js"
    },
    {
      "source": "/storico-notifiche/embed.html",
      "destination": "/storico-notifiche/embed.html"
    },
    {
      "source": "/storico-notifiche",
      "destination": "/storico-notifiche/index.html"
    },
    {
      "source": "/rss-monitor/(.*)",
      "destination": "/rss-monitor/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/storico-notifiche/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://notifiche.comune.digital https://crm.comune.digital https://*.comune.digital https://*.goodbarber.com https://*.goodbarber.app"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
